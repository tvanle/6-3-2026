<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml - Bài 7

    ĐIỂM QUAN TRỌNG:
    - Service PHẢI được khai báo trong AndroidManifest.xml bằng thẻ <service>
    - Nếu không khai báo → hệ thống sẽ không tìm thấy Service → crash
    - android:exported="false": Service chỉ dùng nội bộ trong app
      (không cho phép app khác gọi)
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.bai7_backgroundservice">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Bai7 - Background Service"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar">

        <activity android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Khai báo Service trong Manifest -->
        <!-- exported="false": chỉ cho phép app này gọi, app khác không được -->
        <service
            android:name=".MyService"
            android:exported="false" />

    </application>
</manifest>
