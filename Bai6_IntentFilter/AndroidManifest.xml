<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml - Bài 6: INTENT FILTER

    ĐIỂM QUAN TRỌNG:
    Activity có 2 intent-filter:

    1. intent-filter LAUNCHER: để app có thể mở từ màn hình chính
       - action.MAIN + category.LAUNCHER = hiển thị icon trên launcher

    2. intent-filter SEND: để app nhận dữ liệu chia sẻ từ app khác
       - action.SEND: xử lý hành động gửi/chia sẻ
       - category.DEFAULT: BẮT BUỘC cho implicit intent (nếu thiếu, Android sẽ
         không tìm thấy Activity này khi resolve implicit intent)
       - data mimeType="text/plain": chỉ nhận dữ liệu dạng text
         (có thể thay bằng "image/*" cho ảnh, "*/*" cho mọi loại)

    Khi app khác gửi ACTION_SEND với text/plain:
    → Hệ thống tìm tất cả app có intent-filter phù hợp
    → App này sẽ xuất hiện trong danh sách "Chia sẻ bằng..."
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.bai6_intentfilter">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Bai6 - Email (Intent Filter)"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar">

        <activity android:name=".MainActivity"
            android:exported="true">

            <!-- Intent filter 1: Mở từ Launcher -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Intent filter 2: Nhận dữ liệu chia sẻ dạng text -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>

        </activity>

    </application>
</manifest>
